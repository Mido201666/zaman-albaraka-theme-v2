{# 
  عداد التخفيضات (Countdown)
  Countdown Offer Component
#}

<section class="zab-countdown">
  <div class="zab-countdown__container">
    
    <div class="zab-countdown__content">
      <div class="zab-countdown__eyebrow">✦ {{ component.data.eyebrow|default('عرض لفترة محدودة') }}</div>
      <h2 class="zab-countdown__title">{{ component.data.title|default('خصم 25% على جميع منتجات العود') }}</h2>
      <p class="zab-countdown__desc">{{ component.data.description|default('سارع قبل نفاد الكمية') }}</p>
    </div>

    <div class="zab-countdown__timer" data-end-date="{{ component.data.end_date|default('2026-12-31 23:59:59') }}">
      <div class="zab-countdown__box">
        <div class="zab-countdown__number" data-days>00</div>
        <div class="zab-countdown__label">يوم</div>
      </div>
      <div class="zab-countdown__box">
        <div class="zab-countdown__number" data-hours>00</div>
        <div class="zab-countdown__label">ساعة</div>
      </div>
      <div class="zab-countdown__box">
        <div class="zab-countdown__number" data-minutes>00</div>
        <div class="zab-countdown__label">دقيقة</div>
      </div>
      <div class="zab-countdown__box">
        <div class="zab-countdown__number" data-seconds>00</div>
        <div class="zab-countdown__label">ثانية</div>
      </div>
    </div>

    {% if component.data.btn_text %}
      <a href="{{ component.data.btn_url|default('/offers') }}" class="zab-countdown__btn">
        {{ component.data.btn_text }} ←
      </a>
    {% endif %}

  </div>
</section>

<script>
  (function() {
    var el = document.currentScript.previousElementSibling.previousElementSibling || 
             document.querySelector('.zab-countdown__timer');
    if (!el) return;
    var endDate = new Date(el.getAttribute('data-end-date')).getTime();
    var dEl = el.querySelector('[data-days]');
    var hEl = el.querySelector('[data-hours]');
    var mEl = el.querySelector('[data-minutes]');
    var sEl = el.querySelector('[data-seconds]');
    function pad(n) { return String(n).padStart(2, '0'); }
    function update() {
      var now = new Date().getTime();
      var diff = endDate - now;
      if (diff < 0) {
        dEl.textContent = hEl.textContent = mEl.textContent = sEl.textContent = '00';
        return;
      }
      dEl.textContent = pad(Math.floor(diff / (1000 * 60 * 60 * 24)));
      hEl.textContent = pad(Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)));
      mEl.textContent = pad(Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60)));
      sEl.textContent = pad(Math.floor((diff % (1000 * 60)) / 1000));
    }
    update();
    setInterval(update, 1000);
  })();
</script>

{
  "title": {
    "ar": "عداد التخفيضات",
    "en": "Countdown Offer"
  },
  "description": {
    "ar": "عرض خاص مع عداد تنازلي للوقت المتبقي",
    "en": "Special offer with countdown timer"
  },
  "fields": [
    {
      "id": "eyebrow",
      "type": "text",
      "label": {"ar": "النص العلوي", "en": "Eyebrow"},
      "default": "عرض لفترة محدودة"
    },
    {
      "id": "title",
      "type": "text",
      "label": {"ar": "العنوان", "en": "Title"},
      "default": "خصم 25% على جميع منتجات العود"
    },
    {
      "id": "description",
      "type": "textarea",
      "label": {"ar": "الوصف", "en": "Description"},
      "default": "سارع قبل نفاد الكمية"
    },
    {
      "id": "end_date",
      "type": "text",
      "label": {"ar": "تاريخ انتهاء العرض (YYYY-MM-DD HH:MM:SS)", "en": "End Date"},
      "default": "2026-12-31 23:59:59"
    },
    {
      "id": "btn_text",
      "type": "text",
      "label": {"ar": "نص الزر", "en": "Button Text"},
      "default": "تسوق العروض"
    },
    {
      "id": "btn_url",
      "type": "url",
      "label": {"ar": "رابط الزر", "en": "Button URL"},
      "default": "/offers"
    }
  ]
}

.zab-countdown {
  background: #1C2B47;
  padding: 80px 20px;
  margin: 40px 0;
  border-radius: 16px;
  position: relative;
  overflow: hidden;
  text-align: center;

  &::before,
  &::after {
    content: '';
    position: absolute;
    border: 1.5px solid #C9936B;
    border-radius: 50%;
    opacity: 0.15;
  }

  &::before {
    top: -60px;
    right: -60px;
    width: 240px;
    height: 240px;
  }

  &::after {
    bottom: -60px;
    left: -60px;
    width: 200px;
    height: 200px;
  }

  &__container {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  &__eyebrow {
    color: #C9936B;
    font-size: 14px;
    letter-spacing: 4px;
    font-weight: 700;
    margin-bottom: 18px;
  }

  &__title {
    font-size: 38px;
    color: #fff;
    font-weight: 800;
    margin-bottom: 14px;
    line-height: 1.3;
  }

  &__desc {
    color: #fff;
    opacity: 0.85;
    font-size: 16px;
    margin-bottom: 36px;
  }

  &__timer {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }

  &__box {
    background: rgba(255,255,255,0.05);
    border: 1.5px solid #C9936B;
    border-radius: 12px;
    padding: 20px 18px;
    min-width: 90px;
  }

  &__number {
    color: #C9936B;
    font-size: 40px;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 6px;
  }

  &__label {
    color: #fff;
    font-size: 12px;
    letter-spacing: 2px;
    font-weight: 600;
    text-transform: uppercase;
  }

  &__btn {
    display: inline-block;
    background: #C9936B;
    color: #fff;
    padding: 18px 42px;
    border-radius: 8px;
    font-weight: 800;
    font-size: 15px;
    letter-spacing: 1px;
    text-decoration: none;
    transition: transform 0.3s;

    &:hover {
      transform: translateY(-2px);
      color: #fff;
    }
  }

  @media (max-width: 768px) {
    padding: 50px 20px;

    &__title {
      font-size: 26px;
    }

    &__number {
      font-size: 32px;
    }

    &__box {
      min-width: 70px;
      padding: 14px 10px;
    }
  }
}
