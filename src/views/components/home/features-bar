        <div class="zab-features__icon">
          <i class="{{ component.data.feature_4_icon|default('fas fa-headset') }}"></i>
        </div>
        <div>
          <div class="zab-features__title">{{ component.data.feature_4_title }}</div>
          <div class="zab-features__desc">{{ component.data.feature_4_desc }}</div>
        </div>
      </div>
    {% endif %}

  </div>
</section>

