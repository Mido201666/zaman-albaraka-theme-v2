{# 
  شريط المميزات
  Features Bar Component
#}

<section class="zab-features">
  <div class="zab-features__container">
    
    {% if component.data.feature_1_title %}
      <div class="zab-features__item">
        <div class="zab-features__icon">
          <i class="{{ component.data.feature_1_icon|default('fas fa-shield-halved') }}"></i>
        </div>
        <div>
          <div class="zab-features__title">{{ component.data.feature_1_title }}</div>
